{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run SQLinq Extension (No Source Maps)",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension",
        "--disable-extensions"
      ],
      "sourceMaps": false,
      "smartStep": false,
      "skipFiles": [
        "<node_internals>/**"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/**/*.js"
      ]
    }
  ]
}