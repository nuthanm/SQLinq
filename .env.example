# Product branding — change here only, then run: npm run sync-config
PRODUCT_NAME=SQLinq
PRODUCT_TAGLINE=Free SQL to LINQ for Visual Studio and VS Code
PRODUCT_PHASE=Phase 1 — Microsoft SQL Server · Visual Studio · VS Code
PRODUCT_SINCE_DATE=2026-01-12

# GitHub (live stats + commit grid on the website + automated issue creation)
GITHUB_OWNER=nuthanm
GITHUB_REPO=SQLinq
GITHUB_URL=https://github.com/nuthanm/SQLinq
# GitHub Personal Access Token (required for creating conversion failure issues)
# Scopes needed: repo (full control of private repositories)
# Get token at: https://github.com/settings/tokens
GITHUB_TOKEN=

# Site/API
SITE_URL=
API_BASE_URL=
SITE_DESCRIPTION=Convert any SQL to idiomatic LINQ inside your IDE — free forever, extensible dialect architecture.
FAVICON_PATH=assets/favicon.svg?v=2
PORT=5173

# Neon/PostgreSQL (used by server.js and extension)
# Format: postgres://user:password@host:port/database
# This is the primary database connection - used for telemetry storage and query execution
DATABASE_URL=

# Optional: Other database connections (only configure if you need them)
# SQL Server format: server=hostname;user=sa;password=xxxxx;database=dbname
DATABASE_MSSQL=

# MySQL format: mysql://user:password@localhost:3306/database
DATABASE_MYSQL=

# Oracle format: oracle://user:password@localhost:1521/dbname
DATABASE_ORACLE=

# Aliases for backward compatibility
DATABASE_POSTGRESQL=
POSTGRES_URL=
SQL_SERVER_URL=
MYSQL_URL=
ORACLE_URL=
# Credits shown on website + README
CREDITS_TEXT=Independent SQL to LINQ tooling for Visual Studio and VS Code.
