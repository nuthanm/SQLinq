{
  "name": "sqlinq-vscode-extension",
  "displayName": "SQLinq",
  "description": "Convert basic SQL to LINQ inside VS Code.",
  "version": "0.1.3",
  "publisher": "sqlinq",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sqlinq/sqlinq.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "icon": "assets/icon.png",
  "main": "./extension.js",
  "scripts": {
    "package": "vsce package",
    "install-local": "npm run package && code --install-extension %npm_package_name%-%npm_package_version%.vsix --force"
  },
  "contributes": {
    "commands": [
      {
        "command": "sqlinq.convertSelection",
        "title": "SQLinq: Convert SQL to LINQ"
      },
      {
        "command": "sqlinq.convertSelectionQuick",
        "title": "SQLinq: Quick Convert Selection"
      },
      {
        "command": "sqlinq.openConverterUi",
        "title": "SQLinq: Open Converter UI"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "sqlinq.convertSelection",
          "when": "editorHasSelection",
          "group": "navigation@50"
        },
        {
          "command": "sqlinq.convertSelectionQuick",
          "when": "editorHasSelection",
          "group": "navigation@51"
        },
        {
          "command": "sqlinq.openConverterUi",
          "group": "navigation@52"
        }
      ],
      "explorer/context": [
        {
          "command": "sqlinq.openConverterUi",
          "when": "resourceExtname == .sql || resourceLangId == sql",
          "group": "navigation@50"
        }
      ]
    },
    "configuration": {
      "title": "SQLinq",
      "properties": {
        "sqlinq.telemetryEndpoint": {
          "type": "string",
          "default": "",
          "description": "API endpoint for conversion event sync. When empty, SQLinq uses runtime-config.json or SQLINQ_API_BASE_URL/SITE_URL environment fallback."
        },
        "sqlinq.telemetrySource": {
          "type": "string",
          "default": "vscode-extension",
          "description": "Source label stored with synced conversion events"
        },
        "sqlinq.databaseType": {
          "type": "string",
          "enum": [
            "mssql",
            "postgresql",
            "mysql",
            "oracle",
            "sqlite",
            "connected"
          ],
          "default": "connected",
          "description": "Database tag used in telemetry when connectivity mode is 'with'"
        }
      }
    }
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2"
  }
}
